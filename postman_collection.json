{
  "info": {
    "name": "Freelance Marketplace API",
    "_postman_id": "freelance-marketplace-api-v1",
    "description": "Mini Upwork — Freelance Marketplace API Collection\n\nWorkflow:\n1. Register client and freelancer\n2. Login to get JWT tokens\n3. Client creates a project\n4. Freelancer submits a bid\n5. Client accepts bid (contract created)\n6. Client finishes contract\n7. Client leaves review",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:8000", "type": "string"},
    {"key": "client_token", "value": "", "type": "string"},
    {"key": "freelancer_token", "value": "", "type": "string"},
    {"key": "project_id", "value": "", "type": "string"},
    {"key": "bid_id", "value": "", "type": "string"},
    {"key": "contract_id", "value": "", "type": "string"},
    {"key": "review_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"client1\",\n  \"email\": \"client1@example.com\",\n  \"password\": \"client123\",\n  \"password2\": \"client123\",\n  \"role\": \"client\",\n  \"bio\": \"Looking for talented developers\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/register/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register", ""]}
          }
        },
        {
          "name": "Register Freelancer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"freelancer1\",\n  \"email\": \"freelancer1@example.com\",\n  \"password\": \"freelancer123\",\n  \"password2\": \"freelancer123\",\n  \"role\": \"freelancer\",\n  \"bio\": \"Full-stack developer with 5 years of experience\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/register/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register", ""]}
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) { pm.collectionVariables.set('client_token', json.access); }",
                  "pm.test('Login successful', function() { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"client1\",\n  \"password\": \"client123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/login/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login", ""]}
          }
        },
        {
          "name": "Login Freelancer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) { pm.collectionVariables.set('freelancer_token', json.access); }",
                  "pm.test('Login successful', function() { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"freelancer1\",\n  \"password\": \"freelancer123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/login/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login", ""]}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"<your_refresh_token>\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/logout/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "logout", ""]}
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/profile/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "profile", ""]}
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio text here\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/profile/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "profile", ""]}
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"client123\",\n  \"new_password\": \"newpass123\",\n  \"new_password2\": \"newpass123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/change-password/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "change-password", ""]}
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client1@example.com\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/forgot-password/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "forgot-password", ""]}
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uid\": \"<uid_from_email>\",\n  \"token\": \"<token_from_email>\",\n  \"new_password\": \"resetpass123\",\n  \"new_password2\": \"resetpass123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/reset-password/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "reset-password", ""]}
          }
        },
        {
          "name": "List Freelancers",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/freelancers/", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "freelancers", ""]}
          }
        }
      ]
    },
    {
      "name": "📁 Projects",
      "item": [
        {
          "name": "List Open Projects",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/?search=&budget_min=&budget_max=&ordering=-created_at",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", ""],
              "query": [
                {"key": "search", "value": ""},
                {"key": "budget_min", "value": ""},
                {"key": "budget_max", "value": ""},
                {"key": "ordering", "value": "-created_at"}
              ]
            }
          }
        },
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('project_id', json.id); }",
                  "pm.test('Project created', function() { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"E-commerce Website Development\",\n  \"description\": \"Need a full-stack developer to build an e-commerce platform with Django and React.\",\n  \"budget\": 1500.00,\n  \"deadline\": \"2026-06-30\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/projects/create/", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "create", ""]}
          }
        },
        {
          "name": "My Projects",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/projects/my/", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "my", ""]}
          }
        },
        {
          "name": "Get Project Detail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/projects/{{project_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", ""]}
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"budget\": 2000.00\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/projects/{{project_id}}/update/", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "update", ""]}
          }
        },
        {
          "name": "Cancel Project",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/projects/{{project_id}}/cancel/", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "cancel", ""]}
          }
        },
        {
          "name": "Search Projects by Title",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{freelancer_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/?search=e-commerce",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", ""],
              "query": [{"key": "search", "value": "e-commerce"}]
            }
          }
        },
        {
          "name": "Filter Projects by Budget",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{freelancer_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/?budget_min=500&budget_max=2000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", ""],
              "query": [
                {"key": "budget_min", "value": "500"},
                {"key": "budget_max", "value": "2000"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "💰 Bids",
      "item": [
        {
          "name": "Submit Bid (Freelancer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('bid_id', json.id); }",
                  "pm.test('Bid submitted', function() { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{freelancer_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project\": {{project_id}},\n  \"price\": 1200.00,\n  \"message\": \"I have 5 years of experience in Django and React. I can complete this project in 4 weeks.\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/bids/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", ""]}
          }
        },
        {
          "name": "My Bids (Freelancer)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{freelancer_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/bids/my/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "my", ""]}
          }
        },
        {
          "name": "Get Project Bids (Client)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/bids/project/{{project_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "project", "{{project_id}}", ""]}
          }
        },
        {
          "name": "Get Bid Detail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/bids/{{bid_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "{{bid_id}}", ""]}
          }
        },
        {
          "name": "Update Bid (Freelancer)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{freelancer_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1100.00,\n  \"message\": \"Updated offer: I can deliver in 3 weeks for a better price.\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/bids/{{bid_id}}/update/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "{{bid_id}}", "update", ""]}
          }
        },
        {
          "name": "Accept Bid (Client) ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.contract && json.contract.id) { pm.collectionVariables.set('contract_id', json.contract.id); }",
                  "pm.test('Bid accepted & contract created', function() { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/bids/{{bid_id}}/accept/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "{{bid_id}}", "accept", ""]}
          }
        },
        {
          "name": "Delete Bid (Freelancer)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{freelancer_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/bids/{{bid_id}}/delete/", "host": ["{{base_url}}"], "path": ["api", "v1", "bids", "{{bid_id}}", "delete", ""]}
          }
        }
      ]
    },
    {
      "name": "📄 Contracts",
      "item": [
        {
          "name": "My Contracts",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/contracts/", "host": ["{{base_url}}"], "path": ["api", "v1", "contracts", ""]}
          }
        },
        {
          "name": "Get Contract Detail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/contracts/{{contract_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "contracts", "{{contract_id}}", ""]}
          }
        },
        {
          "name": "Finish Contract (Client) ⭐",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/contracts/{{contract_id}}/finish/", "host": ["{{base_url}}"], "path": ["api", "v1", "contracts", "{{contract_id}}", "finish", ""]}
          }
        },
        {
          "name": "Cancel Contract (Client)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/contracts/{{contract_id}}/cancel/", "host": ["{{base_url}}"], "path": ["api", "v1", "contracts", "{{contract_id}}", "cancel", ""]}
          }
        }
      ]
    },
    {
      "name": "⭐ Reviews",
      "item": [
        {
          "name": "Create Review (Client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('review_id', json.id); }",
                  "pm.test('Review created', function() { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{client_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contract\": {{contract_id}},\n  \"rating\": 5,\n  \"comment\": \"Excellent work! Delivered on time and exceeded expectations. Highly recommended!\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/reviews/", "host": ["{{base_url}}"], "path": ["api", "v1", "reviews", ""]}
          }
        },
        {
          "name": "My Reviews Received (Freelancer)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{freelancer_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/reviews/my/received/", "host": ["{{base_url}}"], "path": ["api", "v1", "reviews", "my", "received", ""]}
          }
        },
        {
          "name": "My Reviews Given (Client)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/reviews/my/given/", "host": ["{{base_url}}"], "path": ["api", "v1", "reviews", "my", "given", ""]}
          }
        },
        {
          "name": "Get Review Detail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/reviews/{{review_id}}/", "host": ["{{base_url}}"], "path": ["api", "v1", "reviews", "{{review_id}}", ""]}
          }
        },
        {
          "name": "Freelancer Reviews by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{client_token}}"}],
            "url": {"raw": "{{base_url}}/api/v1/reviews/freelancer/1/", "host": ["{{base_url}}"], "path": ["api", "v1", "reviews", "freelancer", "1", ""]}
          }
        }
      ]
    }
  ]
}
